@page "/"

<div class="container mt-5">

    <!-- Page Header -->
    <div class="text-center mb-4">
        <h2 class="fw-bold">Daily Nutrition Settings</h2>
        <p class="text-muted">Customize your daily nutrition preferences</p>
    </div>

    <!-- Card -->
    <div class="card shadow-lg p-4 mx-auto" style="max-width:500px; border-radius:15px;">

        <!-- Calories -->
        <div class="mb-4">
            <label class="form-label fw-semibold">
                Daily Calorie Goal
            </label>
            <input 
                class="form-control form-control-lg" 
                placeholder="Enter calories (ex: 1000)" />
        </div>

        <!-- Allergies -->
        <div>
            <label class="form-label fw-semibold mb-3">
                Dietary Restrictions
            </label>

            <div class="row">

                <div class="col-6">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox">
                        <label class="form-check-label">
                            Gluten-Free
                        </label>
                    </div>
                </div>

                <div class="col-6">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox">
                        <label class="form-check-label">
                            Dairy-Free
                        </label>
                    </div>
                </div>

                <div class="col-6 mt-2">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox">
                        <label class="form-check-label">
                            Vegan
                        </label>
                    </div>
                </div>

            </div>
        </div>

        <!-- Submit Button -->
        <button class="btn btn-success mt-4 w-100">
            Submit
        </button>

    </div>
</div>

@code {
    // No C# logic needed for Sprint 1
}
